local farmV1On = false
local farmV2On = false
local isRunningV1 = false
local isRunningV2 = false

local function farmSetup(island)
lastQuestNPC = nil
local tpLoc = ISLAND_TP[island]
enableFly()
if tpLoc then fireTPRemote(tpLoc); task.wait(3) end
enableGS()
end

local function farmTeardown()
disableFly(); disableGS(); lastQuestNPC = nil; stopFarmHitSpam()
end

local function farmLoopV1()
isRunningV1 = true
if not farmV1On then isRunningV1 = false; return end
_G.islandFarmOn = true
farmSetup(selectedIsland)
if autoHitOn then startFarmHitSpam() end
startAbilityLoop(function() return farmV1On end)
if farmStatusPara then farmStatusPara:SetDesc(“Running V1 — “ .. selectedIsland) end
while farmV1On do
local data = ISLANDS[selectedIsland]
if not data then task.wait(1); continue end
for _, pos in ipairs(data.coords) do
if not farmV1On then break end
local fp = Vector3.new(pos.X, pos.Y + farmHeight, pos.Z)
currentFarmVec = fp
moveTo(fp, farmSpeed)
tryAutoQuest()
task.wait(farmTD)
end
if not farmV1On then break end
if farmLD > 0 then
local endT = tick() + farmLD
while tick() < endT and farmV1On do tryAutoQuest(); task.wait(0.5) end
end
end
farmTeardown()
_G.islandFarmOn = false; isRunningV1 = false
if farmStatusPara then farmStatusPara:SetDesc(“Idle”) end
end

local function farmLoopV2()
isRunningV2 = true
if not farmV2On then isRunningV2 = false; return end
_G.islandFarmOn = true
farmSetup(selectedIsland)
if autoHitOn then startFarmHitSpam() end
startAbilityLoop(function() return farmV2On end)
if farmStatusPara then farmStatusPara:SetDesc(“Running V2 — “ .. selectedIsland) end
while farmV2On do
local data = ISLANDS[selectedIsland]
if not data then task.wait(1); continue end
local ci   = data.center
local cpos = data.coords[ci]
local fp   = Vector3.new(cpos.X, cpos.Y + farmHeight, cpos.Z)
currentFarmVec = fp
moveTo(fp, farmSpeed)
tryAutoQuest()
if farmLD > 0 then
local endT = tick() + farmLD
while tick() < endT and farmV2On do tryAutoQuest(); task.wait(0.5) end
else
task.wait(0.5)
end
end
farmTeardown()
_G.islandFarmOn = false; isRunningV2 = false
if farmStatusPara then farmStatusPara:SetDesc(“Idle”) end
end

task.spawn(function()
local wasV1, wasV2 = false, false
while task.wait(0.2) do
if farmV1On and not wasV1 then
farmV2On = false
if not isRunningV1 then task.spawn(farmLoopV1) end
end
if farmV2On and not wasV2 then
farmV1On = false
if not isRunningV2 then task.spawn(farmLoopV2) end
end
wasV1 = farmV1On; wasV2 = farmV2On
end
end)

