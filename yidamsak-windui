local npcName  = data.npc
local bossCoord = data.coord
local tpLoc    = data.tpLoc
if farmStatusPara then bossStatusPara:SetDesc(“Teleporting…”) end
if tpLoc then
fireTPRemote(tpLoc)
for i = 3, 1, -1 do
if not bossKillOn then disableBossFly(); return end
if bossStatusPara then bossStatusPara:SetDesc(“Loading “..i..“s”) end
task.wait(1)
end
end
if not bossKillOn then disableBossFly(); return end
enableBossFly()
if bossStatusPara then bossStatusPara:SetDesc(“Mendekati boss…”) end
local r = getRoot()
if r then
local dist = (r.Position - bossCoord).Magnitude
if dist > 500 then
r.CFrame = CFrame.new(bossCoord + Vector3.new(0,5,0))
if bossFlyBP then bossFlyBP.Position = r.Position end
else
if bossFlyBP then bossFlyBP.Position = bossCoord + Vector3.new(0,5,0) end
local dur = math.max(0.3, dist / farmSpeed)
TweenService:Create(r, TweenInfo.new(dur, Enum.EasingStyle.Linear), {CFrame = CFrame.new(bossCoord+Vector3.new(0,5,0))}):Play()
task.wait(dur)
end
end
task.wait(0.3)
local bossHitRun = true
task.spawn(function()
while bossHitRun and bossKillOn do
local bp = getBossPart(npcName)
if bp then
if not isAlive(bp.Parent or bp) then bossHitRun = false; break end
fireHitAt(bp.Position)
end
task.wait()
end
end)
if bossStatusPara then bossStatusPara:SetDesc(“Menyerang: “ .. npcName) end
while bossKillOn do
local bp = getBossPart(npcName)
if not bp or not isAlive(bp.Parent or bp) then
showNotif(“Auto Boss”, npcName .. “ telah mati!”)
if bossStatusPara then bossStatusPara:SetDesc(“Boss mati — “ .. npcName) end
break
end
local rr = getRoot(); if not rr then task.wait(0.2); continue end
local bossPos = bp.Position
local dist = (rr.Position - bossPos).Magnitude
local hp = getHealth(bp.Parent or bp)
local hpStr = hp >= 0 and (” | HP:”..math.floor(hp)) or “”
if bossStatusPara then bossStatusPara:SetDesc(npcName..” | “..math.floor(dist)..“st”..hpStr) end
local target = bossPos + Vector3.new(0,3,0)
if dist > 500 then
rr.CFrame = CFrame.new(target)
if bossFlyBP then bossFlyBP.Position = target end
elseif dist > 4 then
local dur = math.max(0.05, dist / farmSpeed)
if bossFlyBP then bossFlyBP.Position = target end
TweenService:Create(rr, TweenInfo.new(dur, Enum.EasingStyle.Linear), {CFrame = CFrame.new(target)}):Play()
end
task.wait(0.15)
end
bossHitRun = false
disableBossFly()
if bossStatusPara then bossStatusPara:SetDesc(“Idle”) end
bossKillOn = false; bossOn = false
end

