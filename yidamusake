local function farmLoopV1()
    isRunningV1 = true
    _G.islandFarmOn = true
    enableFly()
    enableGameSettings()
    while farmV1On do
        local data = ISLANDS[islandSelected]
        if not data then task.wait(0.5) continue end
        local coords = data.coords
        for i,pos in ipairs(coords) do
            if not farmV1On then break end
            local finalPos = Vector3.new(pos.X,pos.Y+heightOffset,pos.Z)
            local root = getRoot()
            local dist = root and (root.Position-finalPos).Magnitude or 0
            farmPhaseLabel:Set((dist>100 and "Tween" or "Teleport").." ["..i.."/"..#coords.."]")
            farmStatusLabel:Set(islandSelected)
            moveToPosition(finalPos,tweenSpeed)
            task.wait(teleportDelay)
        end
        if not farmV1On then break end
        if loopDelay > 0 then
            local endT = tick()+loopDelay
            while tick()<endT and farmV1On do
                farmPhaseLabel:Set("Cooldown "..math.ceil(endT-tick()).."s")
                task.wait(0.1)
            end
        end
    end
    disableFly()
    disableGameSettings()
    farmStatusLabel:Set("Status: Idle")
    farmPhaseLabel:Set("Phase: --")
    _G.islandFarmOn = false
    isRunningV1 = false
end

local function farmLoopV2()
    isRunningV2 = true
    _G.islandFarmOn = true
    enableFly()
    enableGameSettings()
    while farmV2On do
        local data = ISLANDS[islandSelected]
        if not data then task.wait(0.5) continue end
        local ci = data.center
        local cpos = data.coords[ci]
        local finalPos = Vector3.new(cpos.X,cpos.Y+heightOffset,cpos.Z)
        local root = getRoot()
        local dist = root and (root.Position-finalPos).Magnitude or 0
        farmStatusLabel:Set(islandSelected.." [center:"..ci.."]")
        farmPhaseLabel:Set(dist>100 and "Tween ke tengah" or "Menetap di tengah")
        moveToPosition(finalPos,tweenSpeed)
        if loopDelay > 0 then
            local endT = tick()+loopDelay
            while tick()<endT and farmV2On do
                farmPhaseLabel:Set("Re-check "..math.ceil(endT-tick()).."s")
                task.wait(0.1)
            end
        else
            task.wait(0.5)
        end
    end
    disableFly()
    disableGameSettings()
    farmStatusLabel:Set("Status: Idle")
    farmPhaseLabel:Set("Phase: --")
    _G.islandFarmOn = false
    isRunningV2 = false
end

task.spawn(function()
    local pV1,pV2 = false,false
    while task.wait(0.2) do
        if farmV1On and not pV1 then
            if not isRunningV1 then task.spawn(farmLoopV1) end
        end
        if farmV2On and not pV2 then
            if not isRunningV2 then task.spawn(farmLoopV2) end
        end
        pV1 = farmV1On
        pV2 = farmV2On
    end
end)

