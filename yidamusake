local QUEST_COUNT = 19

local function findNearestQuestNPC(radius)
    local root = getRoot()
    if not root then return nil,nil end
    local folder = workspace:FindFirstChild("ServiceNPCs")
    if not folder then return nil,nil end
    local best,bestDist,bestName = nil,math.huge,nil
    for i = 1,QUEST_COUNT do
        local name = "QuestNPC"..i
        local npc = folder:FindFirstChild(name)
        if npc then
            local pos
            if npc:IsA("Model") then
                local pp = npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
                if pp then pos = pp.Position end
            elseif npc:IsA("BasePart") then
                pos = npc.Position
            end
            if pos then
                local d = (root.Position - pos).Magnitude
                if d <= radius and d < bestDist then
                    bestDist=d; best=npc; bestName=name
                end
            end
        end
    end
    return best,bestName
end

